{
  "plugins": ["stylelint-prettier"],
  "extends": [
    "stylelint-config-standard-scss",
    "stylelint-config-prettier-scss"
  ],
  "rules": {
    "prettier/prettier": true,
    "selector-pseudo-class-no-unknown": [
      true,
      {
        "ignorePseudoClasses": ["export"]
      }
    ],
    "unit-disallowed-list": [
      ["px", "em", "rem"],
      {
        "ignoreProperties": {
          "px": [
            "border",
            "border-width",
            "letter-spacing",
            "outline",
            "box-shadow"
          ],
          "em": "letter-spacing"
        }
      }
    ]
  }
}
