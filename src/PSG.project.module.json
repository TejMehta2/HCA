{
    "$schema": "../../.sitecPSGore/schemas/ModuleFile.schema.json",
    "namespace": "PSG Project Modules",
    "items": {
        "includes": [
            {
                "name": "PSG Project modules",
                "path": "/sitecore/system/Settings/Project/PSG",
                "allowedPushOperations": "CreateUpdateAndDelete"
                
            },
            {
                "name": "PSG Project placeholder settings",
                "path": "/sitecore/layout/Placeholder Settings/Project/PSG",
                "allowedPushOperations": "CreateUpdateAndDelete"
                
            },    
