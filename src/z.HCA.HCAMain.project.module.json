{
  "$s7chema": "../../.sitecore/schemas/ModuleFile.schema.json",
  "namespace": "HCA Mainsite Project",
  "items": {
    "includes": [
      {
        "name": "HCA Mainsite layout",
        "path": "/sitecore/layout/Placeholder Settings/Project/HCA/HCA Main",
        "allowedPushOperations": "CreateUpdateAndDelete"
      },
      {
        "name": "HCA Mainsite renderings",
        "path": "/sitecore/layout/Renderings/Project/HCA/HCA Main",
        "allowedPushOperations": "CreateUpdateAndDelete"
      },
      {
        "name": "HCA Mainsite templates",
        "path": "/sitecore/templates/Project/HCA/HCA Main",
        "allowedPushOperations": "CreateUpdateAndDelete"
      },
      {
        "name": "HCA Mainsite media",
        "path": "/sitecore/media library/Project/HCA/HCA Main",
        "allowedPushOperations": "CreateUpdateAndDelete"
      },   
      {
        "name": "HCA Mainsite site root",
        "path": "/sitecore/content/HCA",
        "allowedPushOperations": "CreateUpdateAndDelete",
        "scope": "SingleItem"
      },      
      {
        "name": "HCA Mainsite site",
        "path": "/sitecore/content/HCA/HCA Main",
        "rules": [         
          {
            "path": "/home",
            "scope": "SingleItem",
            "allowedPushOperations": "CreateOnly"
          },
          {
            "path": "/Media",
            "scope": "ItemAndChildren",
            "allowedPushOperations": "CreateOnly"
          },        
          {
            "path": "/Data",
            "scope": "ItemAndChildren",
            "allowedPushOperations": "CreateAndUpdate"
          },
          {
            "path": "/Dictionary",
            "scope": "ItemAndChildren",
            "allowedPushOperations": "CreateOnly"
          },
          {
            "path": "/Presentation",
            "scope": "ItemAndDescendants",
            "allowedPushOperations": "CreateAndUpdate"
          },
          {
            "path": "/Settings/Site Grouping",
            "scope": "ItemAndChildren",
            "allowedPushOperations": "CreateOnly"
          },
          {
            "path": "/Settings",
            "scope": "ItemAndChildren",
            "allowedPushOperations": "CreateAndUpdate"
          },                 
          {
            "path": "/*",
            "scope": "Ignored"
          }
        ]
      }
    ]
  }
}