{
    "$schema": "../../.sitecore/schemas/ModuleFile.schema.json",
    "namespace": "z-HCA-Project-Main-Site-Sync",
  "items": {
        "includes": [
            {
                "name": "HCA_SiteContent",
                "path": "/sitecore/content/HCA/HCA-Main/Home",
                "scope": "ItemAndDescendants",
                "allowedPushOperations": "CreateAndUpdate",
                "rules": [
                    {
                        "path": "/Finder",
                        "scope": "ignored"
                    },
                    {
                        "path": "/QA",
                        "scope": "ignored"
                    }
                ]
            },
            {
                "name": "HCA_GlobalData",
                "path": "/sitecore/content/HCA/HCA-Main/Data",
                "allowedPushOperations": "CreateAndUpdate"
            },
            {
                "name": "HCA_Settings",
                "path": "/sitecore/content/HCA/HCA-Main/Settings",
                "allowedPushOperations": "CreateAndUpdate",
                "scope": "DescendantsOnly",
                "rules": [
                    {
                        "path": "/Site Grouping",
                        "scope": "ignored"
                    },
                    {
                        "path": "/Form Api Settings Container",
                        "scope": "ignored"
                    }
                ]
            },
            {
                "name": "HCA_Presentation",
                "path": "/sitecore/content/HCA/HCA-Main/Presentation",
                "allowedPushOperations": "CreateAndUpdate",
                "scope": "DescendantsOnly",
                "rules": [
                    {
                        "path": "/Sitemaps",
                        "scope": "ignored"
                    }
                ]
            }
        ]
    }
}