{
  "name": "HCA-Main",
  "description": "Application utilizing Content SDK and Next.js",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://doc.sitecore.com/xmc/en/developers/content-sdk/index.html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/content-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/content-sdk/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "copy": "cd ../../ && npm i && npm run hcamain-csdk:copy",
    "build": "cross-env NODE_ENV=production npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build next:build",
    "lint": "eslint ./src/**/*.tsx ./src/**/*.ts",
    "next:build": "cross-env NODE_OPTIONS=--max-old-space-size=6144 next build",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev --webpack",
    "next:start": "next start",
    "sitecore-tools:generate-map": "sitecore-tools project component generate-map",
    "sitecore-tools:generate-map:watch": "sitecore-tools project component generate-map --watch",
    "sitecore-tools:build": "sitecore-tools project build",
    "dev": "cross-env NODE_ENV=development npm-run-all --serial sitecore-tools:generate-map sitecore-tools:build --parallel next:dev sitecore-tools:generate-map:watch",
    "start": "cross-env-shell NODE_ENV=production npm-run-all --serial build next:start"
  },
  "dependencies": {
    "@ant-design/react-slick": "^2.0.0",
    "@googlemaps/markerclusterer": "^2.6.2",
    "@googlemaps/react-wrapper": "^1.2.0",
    "@hookform/devtools": "^4.4.0",
    "@hookform/resolvers": "^3.10.0",
    "@neondatabase/serverless": "^1.1.0",
    "@react-pdf/renderer": "^4.1.6",
    "@sitecore-content-sdk/analytics-core": "~2.1.0",
    "@sitecore-content-sdk/events": "~2.1.0",
    "@sitecore-content-sdk/nextjs": "~2.1.0",
    "@sitecore-content-sdk/personalize": "~2.1.0",
    "@sitecore-feaas/clientside": "^0.6.0",
    "@sitecore/components": "~2.1.0",
    "@types/google.maps": "^3.64.0",
    "@types/intl-tel-input": "^18.1.4",
    "@types/react-google-recaptcha": "^2.1.9",
    "@yext/search-headless-react": "^2.7.1",
    "@yext/search-ui-react": "^3.0.3",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.26.2",
    "html-react-parser": "^5.2.11",
    "intl-tel-input": "^23.9.3",
    "next": "^16.2.0",
    "next-intl": "^4.3.5",
    "node-html-parser": "^6.1.13",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.76.0",
    "sass": "^1.99.0",
    "swr": "^2.4.1",
    "use-debounce": "^10.1.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@sitecore-content-sdk/cli": "~2.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-config-next": "16.2.2",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4",
    "typescript": "~5.8.3"
  }
}
