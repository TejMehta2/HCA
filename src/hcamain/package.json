{
  "name": "HCA-Main",
  "description": "Application utilizing Sitecore JavaScript Services and Next.js ",
  "version": "21.6.0",
  "private": true,
  "scripts": {
    "copy": "cd ../../ && npm i && npm run hcamain:copy",
    "bootstrap": "ts-node --project tsconfig.scripts.json scripts/bootstrap.ts",
    "build": "npm-run-all --serial bootstrap next:build",
    "graphql:update": "ts-node --project tsconfig.scripts.json ./scripts/fetch-graphql-introspection-data.ts",
    "install-pre-push-hook": "ts-node --project tsconfig.scripts.json ./scripts/install-pre-push-hook.ts",
    "jss": "jss",
    "next:build": "next build",
    "next:dev": "cross-env NODE_OPTIONS='--inspect' next dev",
    "next:start": "next start",
    "scaffold": "ts-node --project tsconfig.scripts.json scripts/scaffold-component/index.ts",
    "start:connected": "npm-run-all --serial bootstrap --parallel next:dev start:watch-components",
    "start:production": "npm-run-all --serial bootstrap next:build next:start",
    "start:watch-components": "ts-node --project tsconfig.scripts.json scripts/generate-component-builder/index.ts --watch",
    "type-check": "tsc --noemit",
    "lint": "eslint **/*.*{tsx,ts}",
    "format": "prettier --config .prettierrc --write **/*.*{tsx,ts,scss} --fix --ignore-path .prettierignore"
  },
  "config": {
    "appName": "HCA-Main",
    "rootPlaceholders": [
      "jss-main"
    ],
    "sitecoreConfigPath": "/App_Config/Include/zzz",
    "graphQLEndpointPath": "/sitecore/api/graph/edge",
    "language": "en",
    "templates": [
      "nextjs",
      "nextjs-xmcloud",
      "nextjs-sxa",
      "nextjs-multisite"
    ]
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://jss.sitecore.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitecore/jss.git"
  },
  "bugs": {
    "url": "https://github.com/sitecore/jss/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@ant-design/react-slick": "^1.0.2",
    "@googlemaps/markerclusterer": "^2.5.3",
    "@googlemaps/react-wrapper": "^1.1.35",
    "@hookform/devtools": "^4.3.1",
    "@hookform/resolvers": "^3.3.4",
    "@neondatabase/serverless": "^1.0.0",
    "@react-18-pdf/renderer": "^2.3.4",
    "@react-18-pdf/yoga": "^2.0.5",
    "@react-pdf/renderer": "^4.1.6",
    "@sitecore-cloudsdk/events": "^0.1.3",
    "@sitecore-cloudsdk/personalize": "^0.6.0",
    "@sitecore-feaas/clientside": "^0.5.12",
    "@sitecore-jss/sitecore-jss-nextjs": "~21.6.0",
    "@sitecore/components": "^1.1.6",
    "@vercel/edge-config": "^1.4.0",
    "@yext/pages": "^1.0.0",
    "@yext/search-headless-react": "^2.4.0",
    "@yext/search-ui-react": "^1.4.1",
    "axios": "^1.7.7",
    "bootstrap": "^5.1.3",
    "classnames": "^2.5.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^12.26.2",
    "graphql": "~15.8.0",
    "graphql-tag": "^2.12.6",
    "html-react-parser": "^5.2.11",
    "intl-tel-input": "^23.0.7",
    "next": "^13.4.16",
    "next-localization": "^0.12.0",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^6.1.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.51.2",
    "react-intersection-observer": "^9.5.2",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.10.1",
    "react-uuid": "^2.0.0",
    "sass": "^1.52.3",
    "sass-alias": "^1.0.5",
    "sharp": "0.32.6",
    "swr": "^2.2.4",
    "use-debounce": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@ant-design/react-slick": "^1.0.2",
    "@graphql-codegen/cli": "^1.21.8",
    "@graphql-codegen/import-types-preset": "^2.2.6",
    "@graphql-codegen/plugin-helpers": "^3.1.2",
    "@graphql-codegen/typed-document-node": "^2.3.12",
    "@graphql-codegen/typescript": "^2.8.7",
    "@graphql-codegen/typescript-operations": "^2.5.12",
    "@graphql-codegen/typescript-resolvers": "^2.7.12",
    "@graphql-typed-document-node/core": "^3.1.1",
    "@sitecore-jss/sitecore-jss-cli": "~21.6.0",
    "@sitecore-jss/sitecore-jss-dev-tools": "~21.6.0",
    "@svgr/webpack": "^8.1.0",
    "@types/google.maps": "^3.55.9",
    "@types/intl-tel-input": "^18.1.4",
    "@types/node": "^18.11.18",
    "@types/react": "^18.2.22",
    "@types/react-dom": "^18.0.5",
    "@types/react-google-recaptcha": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "chalk": "~4.1.2",
    "chokidar": "~3.5.3",
    "constant-case": "^3.0.4",
    "cross-env": "~7.0.3",
    "dotenv": "^16.0.3",
    "eslint": "^8.51.0",
    "eslint-config-next": "^13.5.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-yaml": "^0.5.0",
    "graphql-let": "^0.18.6",
    "npm-run-all": "~4.1.5",
    "prettier": "^3.0.3",
    "react-intersection-observer": "^9.5.2",
    "stylelint": "^15.10.3",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-prettier": "^4.0.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^5.3",
    "vercel": "^32.5.3",
    "yaml-loader": "^0.8.0"
  }
}
