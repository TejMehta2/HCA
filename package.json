{
  "name": "hca-workspace",
  "workspaces": [
    "src/component-library",
    "src/hcamain"
  ],
  "scripts": {
    "storybook": "npm run storybook -w src/component-library",
    "start:hcamain": "npm run start:connected -w src/hcamain",
    "scaffold": "npm run scaffold -w src/component-library",
    "test:component-library": "npm run test -w src/component-library",
    "lint": "npm run lint:ts && npm run lint:scss",
    "lint:ts": "eslint src/**/*.*{tsx,ts}",
    "lint:scss": "npx stylelint \"**/*.scss\"",
    "format": "npm run format:ts && npm run format:scss",
    "format:ts": "prettier --config .prettierrc --write **/*.*{tsx,ts,scss}",
    "format:scss": "npx stylelint \"**/*.scss\" --fix",
    "stylelint-scss-check": "stylelint-config-prettier-scss-check",
    "storybook:publish": "npm run chromatic -w src/component-library"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "chromatic": "^7.4.0",
    "eslint": "^8.51.0",
    "eslint-config-next": "^13.5.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-yaml": "^0.5.0",
    "prettier": "^3.0.3",
    "stylelint": "^15.10.3",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-prettier": "^4.0.2",
    "ts-node": "^10.9.1"
  }
}