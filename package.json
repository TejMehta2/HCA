{
  "name": "hca-workspace",
  "workspaces": [
    "src/component-library",
    "src/hcamain",
    "src/microsite"
  ],
  "scripts": {
    "component-library:storybook": "npm run storybook -w src/component-library",
    "component-library:storybook:publish": "npm run chromatic -w src/component-library",
    "component-library:scaffold": "npm run scaffold -w src/component-library",
    "component-library:type-check": "npm run type-check -w src/component-library",
    "component-library:test": "npm run test -w src/component-library",
	
    "hcamain:start": "dotnet leprechaun /c HCALeprechaun.config && dotnet leprechaun /c PSGLeprechaun.config && npm run start:connected -w src/hcamain",
    "hcamain:start:production": "npm run start:production -w src/hcamain",
    "hcamain:build": "npm run build -w src/hcamain",
    "hcamain:next:start": "npm run next:start -w src/hcamain",
    "hcamain:type-check": "npm run bootstrap -w src/hcamain && npm run type-check -w src/hcamain",
    "hcamain:copy": "npm run copy -w src/component-library hcamain/src/temp",
    "microsite:start": "npm run start:connected -w src/microsite",
    "microsite:start:production": "npm run start:production -w src/microsite",
    "microsite:build": "npm run build -w src/microsite",
    "microsite:next:start": "npm run next:start -w src/microsite",
    "lint": "npm run lint:ts && npm run lint:scss && npm run hcamain:type-check && npm run component-library:type-check",
    "lint:ts": "eslint src/**/*.*{tsx,ts}",
    "lint:scss": "npx stylelint \"**/*.scss\" --ignore-path .prettierignore",
    "format": "npm run format:ts && npm run format:scss --ignore-path .prettierignore",
    "format:ts": "prettier --config .prettierrc --write **/*.*{tsx,ts,scss} --fix --ignore-path .prettierignore",
    "format:scss": "npx stylelint \"**/*.scss\" --fix --ignore-path .prettierignore",
    "stylelint-scss-check": "stylelint-config-prettier-scss-check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "chromatic": "^7.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.51.0",
    "eslint-config-next": "^13.5.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-yaml": "^0.5.0",
    "prettier": "^3.0.3",
    "stylelint": "^15.10.3",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-prettier": "^4.0.2",
    "ts-node": "^10.9.1",
    "vercel": "^32.5.3"
  },
  "dependencies": {
    "use-debounce": "^10.0.0"
  }
}